PWNED_ENV=dev
PWNED_LOG_LEVEL=info

PWNED_S3_ENDPOINT=http://127.0.0.1:9000
PWNED_S3_ACCESS_KEY=minio
PWNED_S3_SECRET_KEY=minio123
PWNED_S3_REGION=us-east-1
PWNED_S3_BUCKET=leaks
PWNED_S3_USE_SSL=false
PWNED_S3_AUTO_CREATE_BUCKET=true

PWNED_MANIFEST_LOCAL_DIR=.state/manifests
PWNED_NORMALIZED_LOCAL_DIR=.state/normalized
PWNED_CHUNK_MAX_BYTES=8388608
PWNED_CHUNK_MAX_RECORDS=50000
PWNED_PARSER_MAX_LINE_BYTES=16777216

PWNED_QUICKWIT_BASE_URL=http://127.0.0.1:7280
PWNED_QUICKWIT_INDEX_ID=leaks
PWNED_QUICKWIT_INDEX_CONFIG=leaks.yml
PWNED_QUICKWIT_COMMIT_MODE=wait_for
PWNED_QUICKWIT_AUTO_CREATE_INDEX=true
PWNED_QUICKWIT_HTTP_TIMEOUT=5m

PWNED_UPLOAD_MAX_RETRIES=3
PWNED_UPLOAD_RETRY_BASE_DELAY=250ms
PWNED_UPLOAD_RETRY_MAX_DELAY=3s

PWNED_COMMAND_TIMEOUT=30m
